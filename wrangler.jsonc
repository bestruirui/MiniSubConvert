{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "minisubconvert",
	"main": "src/worker.js",
	"compatibility_date": "2025-09-27",
	"observability": {
		"enabled": true
	},
	"compatibility_flags": [
		"nodejs_compat"
	],
	"migrations": [
		{
			"new_sqlite_classes": [
				"MiniSubConvert"
			],
			"tag": "v1"
		}
	],
	"durable_objects": {
		"bindings": [
			{
				"class_name": "MiniSubConvert",
				"name": "MiniSubConvert"
			}
		]
	}
}